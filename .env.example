# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=https://novasaas-bot-production.up.railway.app

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...          # "anon public" key
SUPABASE_SERVICE_KEY=eyJ...       # "service_role" key (keep secret)

# ── Stripe ────────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# https://dashboard.stripe.com/webhooks  →  add endpoint: /api/billing/webhook
# Events to send: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — https://dashboard.stripe.com/products
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Binance (optional) ────────────────────────────────────────────────────────
# Comma-separated symbols to stream. Defaults to btcusdt,ethusdt,bnbusdt,solusdt
BINANCE_SYMBOLS=btcusdt,ethusdt,bnbusdt,solusdt
